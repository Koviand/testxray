{
  "remark": "autoXRAY — VLESS gRPC TLS (8411)",
  "enable": true,
  "listen": "127.0.0.1",
  "port": 8411,
  "protocol": "vless",
  "tag": "vsGRPCtls",
  "settings": "{\"clients\":[{\"id\":\"{{UUID}}\",\"email\":\"{{EMAIL}}\",\"enable\":true,\"subId\":\"{{SUB_ID}}\"}],\"decryption\":\"none\"}",
  "streamSettings": "{\"network\":\"grpc\",\"security\":\"none\",\"grpcSettings\":{\"serviceName\":\"{{PATH_XHTTP}}11\"}}",
  "sniffing": "{\"enabled\":true,\"destOverride\":[\"http\",\"tls\",\"quic\"]}"
}
